# Muninn — environment configuration
# Copy to .env and edit. Never commit .env.

# ── Storage paths (override defaults) ─────────────────────────────
# Defaults: ./raw/ for source files, ./data/ for derived artifacts.
# MUNINN_RAW_DIR=/opt/muninn/raw
# MUNINN_DATA_DIR=/opt/muninn/data

# ── Database ──────────────────────────────────────────────────────
# Defaults to $MUNINN_DATA_DIR/muninn.db.
# MUNINN_DB_PATH=/opt/muninn/data/muninn.db

# ── Anthropic API (Haiku bulk enrichment) ─────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Scrape etiquette ──────────────────────────────────────────────
# Contact URL advertised in the scraper's User-Agent string.
# MUNINN_CONTACT_URL=https://your-contact-page.example

# ── Qdrant (vector index, homelab LXC) ────────────────────────────
QDRANT_URL=http://192.168.86.19:6333
QDRANT_COLLECTION=muninn_bookmarks

# ── Embeddings (semantic index) ───────────────────────────────────
# Backend: sentence-transformers (default; local EmbeddingGemma — needs
# `pip install 'muninn[embeddings]'`) or hash (deterministic offline
# placeholder — never ship search on it).
# MUNINN_EMBEDDING_BACKEND=sentence-transformers
# MUNINN_EMBEDDING_MODEL=google/embeddinggemma-300m
# MUNINN_EMBEDDING_DIM=768

# ── Vault (Obsidian-compatible compiled output) ───────────────────
# ROOT of the compiled vault repo (muninn-vault checkout). The compiler
# writes pages into $MUNINN_VAULT_DIR/wiki/bookmarks/.
MUNINN_VAULT_DIR=/path/to/muninn-vault

# Personal vault — guard against MUNINN_VAULT_DIR matching this.
# The generator REFUSES to write if these resolve to the same path.
# (See SPEC.md Decision 2: two vaults, never one.)
MUNINN_PERSONAL_VAULT_DIR=/path/to/personal-vault

# ── Synthesis container ───────────────────────────────────────────
# Path on host to mount as the workspace.
MUNINN_SYNTHESIS_WORKSPACE=/tmp/muninn-synthesis
# Saga's named volume holding the Claude Max credentials. Must exist.
SAGA_CREDENTIALS_VOLUME=saga-claude-credentials

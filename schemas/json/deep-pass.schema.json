{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "$id": "deep-pass.schema.json",
  "title": "Deep Pass Analysis",
  "description": "Schema for deep-pass per-bookmark synthesis output",
  "type": "object",
  "required": [
    "summary",
    "tags",
    "entities",
    "content_type",
    "language",
    "word_count",
    "key_quotes",
    "cross_references",
    "synthesis_metadata"
  ],
  "additionalProperties": false,
  "properties": {
    "bookmark_id": { "type": "integer" },
    "summary": { "type": "string", "minLength": 100 },
    "tags": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "type": { "type": "string", "minLength": 1 }
        }
      }
    },
    "content_type": { "type": "string", "minLength": 1 },
    "language": { "type": "string", "minLength": 2, "maxLength": 10 },
    "word_count": { "type": "integer", "minimum": 0 },
    "key_quotes": {
      "type": "array",
      "items": { "type": "string", "maxLength": 500 },
      "maxItems": 5
    },
    "cross_references": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["target_bookmark_id", "relationship", "confidence"],
        "additionalProperties": false,
        "properties": {
          "target_bookmark_id": { "type": "integer" },
          "relationship": { "type": "string", "minLength": 1 },
          "rationale": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "synthesis_metadata": {
      "type": "object",
      "required": [
        "model",
        "prompt_version",
        "input_token_count",
        "output_token_count"
      ],
      "additionalProperties": false,
      "properties": {
        "model": { "type": "string", "minLength": 1 },
        "prompt_version": { "type": "string", "minLength": 1 },
        "input_token_count": { "type": "integer", "minimum": 0 },
        "output_token_count": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
